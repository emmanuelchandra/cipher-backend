# Dependency yang akan di-install ulang di dalam container
/vendor
/node_modules

# File environment lokal — JANGAN ikut ter-copy ke image
.env
.env.backup
.env.production

# Folder build & cache lokal
/public/build
/public/hot
/public/storage
/storage/*.key
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*

# File git & editor
.git
.gitignore
.idea
.vscode
*.log

# File testing
/.phpunit.cache
/tests
phpunit.xml

# Database lokal SQLite (kalau ada)
/database/database.sqlite

# Dokumentasi / file OS
README.md
.DS_Store
